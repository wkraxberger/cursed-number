# Base URL of the read API that exposes the site state.
# The frontend will GET `${CURSED_API_BASE_URL}/state` server-side on every
# request. When unset, the frontend falls back to deterministic seed data in
# lib/seed.ts so pages still render during local development without a
# backend.
CURSED_API_BASE_URL=

# Dev-only flag. Set to "1" to force the memorial / dead state regardless of
# what the backend returns. Useful for previewing the tombstone and
# "SIGNAL LOST" visuals without a real draw.
CURSED_FORCE_DEAD=

# Dev-only flag. Set to "1" to force the pre-launch "waiting for first signal"
# state (empty draws array) so you can preview what the site looks like
# before any draws have happened.
CURSED_FORCE_WAITING=

# Cloudflare Web Analytics beacon token. When set, a lightweight analytics
# snippet is injected into every page. When unset, no analytics script is
# loaded. Get one at dash.cloudflare.com -> Analytics & Logs -> Web Analytics.
# Must be prefixed with NEXT_PUBLIC_ so it's available in client-side code.
NEXT_PUBLIC_CF_ANALYTICS_TOKEN=
